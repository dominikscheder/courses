<text layer="gamma" matrix="1 0 0 1 -48 0" transformations="translations" pos="512 256" stroke="black" type="label" width="194.138" height="16.6176" depth="2.976" valign="baseline" size="small">The Quicksort Tree</text>
<text layer="delta" transformations="translations" pos="32 224" stroke="black" type="minipage" width="672" height="32.0256" depth="20.112" valign="top" size="small">\textbf{Definition.} $A_{x,y}$ is $1$ if $x$ is an ancestor of $y$ in the Quicksort tree; otherwise, $A_{x,y}$ is $0$.</text>
<text layer="epsilon" matrix="1 0 0 1 -32 0" transformations="translations" pos="304 352" stroke="red" type="label" width="84.48" height="16.3392" depth="6.84" valign="baseline" size="small" style="math">A_{i,e} = 1</text>
