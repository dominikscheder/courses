<text layer="alpha" matrix="1 0 0 1 -16 128" transformations="translations" pos="32 368" stroke="black" type="label" width="464.952" height="17.9208" depth="10.44" valign="baseline" size="small" style="math">\mathbf{E}[ \textnormal{number of comparisons}] = \sum_i \sum_{j \ne i} \mathbf{E} [A_{i,j}]</text>
<text matrix="1 0 0 1 448 128" transformations="translations" pos="32 368" stroke="black" type="label" width="195.058" height="20.1984" depth="12.432" valign="baseline" size="small" style="math"> = \sum_{i} \sum_{j \ne i} 
\frac{1}{|i-j|+1} </text>
<text matrix="1 0 0 1 -8.6954 70.876" transformations="translations" pos="32 368" stroke="black" type="label" width="197.359" height="23.1096" depth="8.232" valign="baseline" size="small" style="math"> = 2 \cdot \sum_{i=1}^n \sum_{k=2}^{i}
\frac{1}{k}  </text>
<text layer="beta" matrix="1 0 0 1 -8.6954 22.876" transformations="translations" pos="32 368" stroke="black" type="label" width="351.449" height="20.3208" depth="9.168" valign="baseline" size="small" style="math"> = 2 \cdot \sum_{i=1}^n 
\left( \sum_{k=2}^{n} \frac{1}{k}  
 - \sum_{k = i+1}^n \frac{1}{k}
  \right)</text>
<text layer="gamma" matrix="1 0 0 1 -8.6954 -25.124" transformations="translations" pos="32 368" stroke="black" type="label" width="420.149" height="20.1984" depth="9.168" valign="baseline" size="small" style="math"> = 2 \cdot \sum_{i=1}^n 
 \sum_{k=2}^{n} \frac{1}{k}  
 - 2 \cdot \sum_{i=1}^n 
 \sum_{k = i+1}^n \frac{1}{k}</text>
